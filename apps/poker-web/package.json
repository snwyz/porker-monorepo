{
  "name": "@poker/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "updateI18nResource": "node scripts/update-i18n-resource.mjs",
    "predev": "pnpm run updateI18nResource && pnpm --filter @poker/i18n build",
    "dev": "node server.mjs",
    "prebuild": "pnpm run updateI18nResource && pnpm --filter @poker/i18n build",
    "build": "next build --webpack",
    "start": "NODE_ENV=production node server.mjs",
    "test": "vitest run src",
    "test:e2e": "playwright test",
    "test:runtime": "node --check server.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --check ."
  },
  "dependencies": {
    "@poker/i18n": "workspace:*",
    "@poker/shared": "workspace:*",
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-slider": "^1.4.3",
    "@reown/appkit": "^1.8.22",
    "@reown/appkit-adapter-wagmi": "^1.8.22",
    "@tanstack/react-query": "^5.101.2",
    "@wagmi/connectors": "6.2.0",
    "@wagmi/core": "2.22.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.24.0",
    "motion": "^12.42.2",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.81.0",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.6.0",
    "viem": "^2.55.2",
    "wagmi": "^2.19.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
