FROM node:22-alpine AS builder

WORKDIR /app
ARG NPM_REGISTRY=https://registry.npmmirror.com
ARG APP_MODE=points
ARG NEXT_PUBLIC_POKER_TOKEN_ADDRESS
ARG NEXT_PUBLIC_ESCROW_ADDRESS
ARG NEXT_PUBLIC_WALLET_LOGIN_DOMAIN
ARG NEXT_PUBLIC_WALLET_LOGIN_URI
ARG NEXT_PUBLIC_REOWN_PROJECT_ID
ENV PRISMA_ENGINES_MIRROR=https://npmmirror.com/mirrors/prisma
RUN npm install --global pnpm@11.13.1 --registry=${NPM_REGISTRY}
COPY . .
RUN pnpm install --frozen-lockfile --registry=${NPM_REGISTRY}
ENV NEXT_TELEMETRY_DISABLED=1
ENV APP_MODE=${APP_MODE}
ENV NEXT_PUBLIC_POKER_TOKEN_ADDRESS=${NEXT_PUBLIC_POKER_TOKEN_ADDRESS}
ENV NEXT_PUBLIC_ESCROW_ADDRESS=${NEXT_PUBLIC_ESCROW_ADDRESS}
ENV NEXT_PUBLIC_WALLET_LOGIN_DOMAIN=${NEXT_PUBLIC_WALLET_LOGIN_DOMAIN}
ENV NEXT_PUBLIC_WALLET_LOGIN_URI=${NEXT_PUBLIC_WALLET_LOGIN_URI}
ENV NEXT_PUBLIC_REOWN_PROJECT_ID=${NEXT_PUBLIC_REOWN_PROJECT_ID}
RUN pnpm --filter @poker/web... build

FROM node:22-alpine AS runtime

WORKDIR /app
RUN addgroup --system poker && adduser --system --ingroup poker poker
ENV NODE_ENV=production
ARG APP_MODE=points
ENV APP_MODE=${APP_MODE}
ENV NEXT_TELEMETRY_DISABLED=1
ENV HOSTNAME=0.0.0.0
ENV PORT=3000
COPY --from=builder --chown=poker:poker /app /app
USER poker
WORKDIR /app/apps/web
EXPOSE 3000
CMD ["node", "server.mjs"]
