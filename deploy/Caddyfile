(points_routes) {
	handle /health/* {
		reverse_proxy poker-api:3001
	}

	handle_path /api/game/* {
		reverse_proxy poker-api:3001
	}

	handle_path /api/* {
		reverse_proxy poker-api:3001
	}

	handle /socket.io/* {
		reverse_proxy poker-api:3001
	}

	handle {
		reverse_proxy poker-web:3000
	}
}

http://{$DOMAIN:localhost} {
	import points_routes
}

https://{$DOMAIN:localhost} {
	tls internal
	import points_routes
}
