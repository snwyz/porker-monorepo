{
  "name": "@poker/agents",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "agents": "./dist/cli.js"
  },
  "scripts": {
    "agents": "node dist/cli.js",
    "build": "tsc --project tsconfig.json",
    "test": "vitest run src",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "lint": "eslint src",
    "format": "prettier --check package.json tsconfig.json src"
  },
  "dependencies": {
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^24.13.3"
  }
}
