generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String              @id @default(cuid())
  displayName      String              @unique
  walletAddress    String?             @unique
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  sessions         Session[]
  seats            Seat[]
  auditLogs        AuditLog[]
  disconnectGraces DisconnectGrace[]
  walletNonces     WalletNonce[]
  chainDeposits    ChainDepositEvent[]
}

model WalletNonce {
  id         String    @id @default(cuid())
  address    String
  nonceHash  String    @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())
  userId     String?
  user       User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([address, expiresAt])
}

model Session {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Room {
  id                   String            @id @default(cuid())
  name                 String
  status               String            @default("WAITING")
  visibility           String            @default("PUBLIC")
  gameType             String            @default("CASH")
  seatCount            Int               @default(9)
  smallBlind           BigInt
  bigBlind             BigInt
  minBuyIn             BigInt
  maxBuyIn             BigInt
  actionTimeoutSeconds Int               @default(30)
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  seats                Seat[]
  hands                Hand[]
  snapshots            GameSnapshot[]
  disconnectGraces     DisconnectGrace[]
}

model Seat {
  id         String   @id @default(cuid())
  roomId     String
  userId     String?
  seatNumber Int
  status     String   @default("OPEN")
  stack      BigInt   @default(0)
  buyIn      BigInt   @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  room       Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([roomId, seatNumber])
  @@unique([roomId, userId])
  @@index([userId])
}

model Hand {
  id               String         @id @default(cuid())
  roomId           String
  handNumber       BigInt
  status           String         @default("IN_PROGRESS")
  pot              BigInt         @default(0)
  startedAt        DateTime       @default(now())
  completedAt      DateTime?
  actionDeadlineAt DateTime?
  room             Room           @relation(fields: [roomId], references: [id], onDelete: Cascade)
  events           HandEvent[]
  snapshots        GameSnapshot[]

  @@unique([roomId, handNumber])
}

model HandEvent {
  id                BigInt   @id @default(autoincrement())
  handId            String
  sequence          Int
  version           Int
  type              String
  payload           Json
  actionId          String?  @unique
  actorUserId       String?
  actionRoomId      String?
  actionPayloadHash String?
  ack               Json?
  createdAt         DateTime @default(now())
  hand              Hand     @relation(fields: [handId], references: [id], onDelete: Cascade)

  @@unique([handId, sequence])
  @@index([handId, version])
}

model GameSnapshot {
  id        BigInt   @id @default(autoincrement())
  roomId    String
  handId    String
  version   BigInt
  state     Json
  createdAt DateTime @default(now())
  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  hand      Hand     @relation(fields: [handId], references: [id], onDelete: Cascade)

  @@unique([handId, version])
  @@index([roomId, createdAt])
  @@index([handId])
}

model DisconnectGrace {
  id         BigInt   @id @default(autoincrement())
  roomId     String
  userId     String
  deadlineAt DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  room       Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
  @@index([deadlineAt])
}

model TableOperation {
  actionId    String   @id
  roomId      String
  userId      String
  type        String
  handId      String?
  payloadHash String
  ack         Json
  createdAt   DateTime @default(now())

  @@index([roomId, userId])
}

model LedgerAccount {
  id        String        @id
  createdAt DateTime      @default(now())
  entries   LedgerEntry[]
}

model LedgerTransaction {
  id           String             @id @default(cuid())
  reference    String             @unique
  payloadHash  String
  finalizedAt  DateTime?
  createdAt    DateTime           @default(now())
  entries      LedgerEntry[]
  chainDeposit ChainDepositEvent?
}

model ChainCheckpoint {
  chainId     BigInt   @id
  blockNumber BigInt
  blockHash   String
  updatedAt   DateTime @updatedAt
}

model ChainCheckpointHistory {
  chainId     BigInt
  blockNumber BigInt
  blockHash   String
  createdAt   DateTime @default(now())

  @@id([chainId, blockNumber])
  @@index([chainId, blockNumber(sort: Desc)])
}

model ChainIndexerLease {
  chainId    BigInt   @id
  generation BigInt
  updatedAt  DateTime @updatedAt
}

model ChainDepositEvent {
  id                  String             @id
  chainId             BigInt
  transactionHash     String
  logIndex            Int
  blockNumber         BigInt
  blockHash           String
  walletAddress       String
  amount              BigInt
  status              String
  revision            Int                @default(0)
  userId              String?
  ledgerTransactionId String?            @unique
  createdAt           DateTime           @default(now())
  user                User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  ledgerTransaction   LedgerTransaction? @relation(fields: [ledgerTransactionId], references: [id], onDelete: SetNull)

  @@unique([chainId, transactionHash, logIndex])
  @@index([chainId, blockNumber])
  @@index([walletAddress])
}

model LedgerEntry {
  id            BigInt            @id @default(autoincrement())
  transactionId String
  accountId     String
  amount        BigInt
  createdAt     DateTime          @default(now())
  transaction   LedgerTransaction @relation(fields: [transactionId], references: [id], onDelete: Restrict)
  account       LedgerAccount     @relation(fields: [accountId], references: [id], onDelete: Restrict)

  @@index([transactionId])
  @@index([accountId])
}

model AuditLog {
  id          BigInt   @id @default(autoincrement())
  actorUserId String?
  action      String
  targetType  String
  targetId    String
  metadata    Json?
  createdAt   DateTime @default(now())
  actor       User?    @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId])
  @@index([targetType, targetId])
}
