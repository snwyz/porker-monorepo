{
  "name": "@poker/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "prisma generate && tsc --project tsconfig.json",
    "test": "prisma generate && vitest run --no-file-parallelism src",
    "typecheck": "prisma generate && tsc --project tsconfig.json --noEmit",
    "lint": "eslint src",
    "format": "prettier --check package.json tsconfig.json src",
    "prisma": "prisma"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "prisma": "^6.19.2"
  }
}
